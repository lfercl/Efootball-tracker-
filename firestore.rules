rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isGroupMemberFromResource() {
      return isSignedIn() && resource.data.memberUids is list && request.auth.uid in resource.data.memberUids;
    }

    function isGroupAdminFromResource() {
      return isSignedIn() && resource.data.adminUids is list && request.auth.uid in resource.data.adminUids;
    }

    function canCreateGroupDoc() {
      return isSignedIn()
        && request.resource.data.groupCode is string
        && request.resource.data.memberUids is list
        && request.auth.uid in request.resource.data.memberUids
        && request.resource.data.value is map
        && request.resource.data.value.memberUids is list
        && request.auth.uid in request.resource.data.value.memberUids
        && request.resource.data.updatedAt is number;
    }

    function canUpdateGroupDoc() {
      return isSignedIn()
        && (
          isGroupMemberFromResource()
          || isGroupAdminFromResource()
          || !(resource.data.memberUids is list)
        )
        && request.resource.data.groupCode == resource.data.groupCode
        && request.resource.data.memberUids is list
        && request.auth.uid in request.resource.data.memberUids
        && request.resource.data.value is map
        && request.resource.data.value.memberUids is list
        && request.auth.uid in request.resource.data.value.memberUids
        && request.resource.data.updatedAt is number;
    }

    function canReadGroupDoc() {
      return isGroupMemberFromResource() || isGroupAdminFromResource() || !(resource.data.memberUids is list);
    }

    match /sharedStorage/{document=**} {
      allow read: if canReadGroupDoc();
      allow create: if canCreateGroupDoc();
      allow update: if canUpdateGroupDoc();
      allow delete: if isGroupAdminFromResource();
    }

    match /pushTokens/{tokenId} {
      allow read: if false;
      allow create, update: if
        isSignedIn() &&
        request.resource.data.keys().hasOnly([
          'token',
          'groupCode',
          'playerName',
          'playerId',
          'platform',
          'origin',
          'enabled',
          'updatedAt'
        ]) &&
        request.resource.data.token is string &&
        request.resource.data.token.size() > 20 &&
        request.resource.data.token.size() < 4096 &&
        request.resource.data.groupCode is string &&
        request.resource.data.groupCode.size() > 0 &&
        request.resource.data.groupCode.size() <= 12 &&
        request.resource.data.playerName is string &&
        request.resource.data.playerName.size() <= 80 &&
        request.resource.data.playerId is string &&
        request.resource.data.playerId.size() <= 120 &&
        request.resource.data.platform is string &&
        request.resource.data.platform.size() <= 20 &&
        request.resource.data.origin is string &&
        request.resource.data.origin.size() <= 300 &&
        request.resource.data.enabled == true &&
        request.resource.data.updatedAt is number;
      allow delete: if isSignedIn();
    }
  }
}
